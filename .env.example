# OpenRouter (OpenAI-compatible) credentials used by the Agents SDK client.
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL_NAME=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: attribution headers OpenRouter uses for its public leaderboards.
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=ATS-CV-Agent

# SQLite database file location.
DATABASE_PATH=data/ats_history.db

# Disable Agents SDK tracing (tracing exporter expects an OpenAI API key by default).
DISABLE_TRACING=true

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
